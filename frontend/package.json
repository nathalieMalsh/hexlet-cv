{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "src/main.tsx",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "cd .. && husky frontend/.husky",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "preview": "vite preview --host 0.0.0.0 --port $PORT"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{js,mjs,cjs,json,md,html,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@inertiajs/inertia": "^0.11.1",
    "@inertiajs/progress": "^0.1.2",
    "@inertiajs/react": "^2.2.8",
    "@mantine/core": "^8.2.1",
    "@mantine/form": "^8.2.1",
    "@mantine/hooks": "^8.2.1",
    "@mantinex/dev-icons": "^2.0.0",
    "@tabler/icons-react": "^3.36.1",
    "@types/node": "^24.12.0",
    "i18next": "^25.6.3",
    "i18next-browser-languagedetector": "^8.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^16.3.5",
    "react-router": "^7.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/react": "^18.2.41",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.6.0",
    "cookie": "^1.1.1",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-fsd-lint": "^1.0.10",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "msw": "^2.12.4",
    "prettier": "3.8.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.4"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
